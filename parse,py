import argparse
from bs4 import BeautifulSoup
import os
import sys
import re

def extract_text_from_html(file_path, output_folder, prefix=""):
    # Take second line of the file and check if it contains the special comment
    comment_number = None
    with open(file_path, "r", encoding="utf-8") as f:
        lines = f.readlines()
        if len(lines) > 1:
            second_line = lines[1].strip()
            match = re.search(r"/players/(\d+)", second_line)
            if match:
                comment_number = match.group(1)                    

    with open(file_path, "r", encoding="utf-8") as f:
        html_content = f.read()

    soup = BeautifulSoup(html_content, "html.parser")

    for script in soup(["script", "style"]):
        script.decompose()
    text = soup.get_text(separator="\n")

    if comment_number:
        base_name = os.path.splitext(os.path.basename(file_path))[0]
        base_name = base_name.split('—')[0] + '— ' + comment_number
    else:
        base_name = os.path.splitext(os.path.basename(file_path))[0]

    # Add prefix to the base_name
    base_name = prefix + base_name
    
    #print(text)
    
    blacklist = ["eFHUB", "Players", "Community", "English", "Sign in", "Compare", "My Builds", "Community Builds", "Save Build", "Share", "SCREENSHOT", "SETTINGS", "Packs"]
    lines = [line.strip() for line in text.splitlines()]
    text = "\n".join(line for line in lines if line and "+" not in line and not any(word in line for word in blacklist))
    
    # Change "-" with " " in the text
    text = text.replace("-", " ")
    #Change "Hell Trick" for "Heel Trick"
    text = text.replace("Hell Trick", "Heel Trick")
    # Change "Chest Measurement" for "Chest"
    text = text.replace("Chest Measurement", "Chest")
    
    lines = text.splitlines()
    Name = lines[0] if len(lines) > 0 else ""
    Style = lines[1] if len(lines) > 1 else ""
    Position = lines[3] if len(lines) > 3 else ""
    #print (f"\033[94mName: {Name}, Style: {Style}, Position: {Position}\033[0m")
    
    training = ["SHO","PAS","DRI","DEX","LBS","AER","DEF","GK1","GK2","GK3"]
    training_dict = {}
    for i, line in enumerate(lines):
        if line in training:
            if i + 1 < len(lines):
                value = re.sub(r"[^\d.]", "", lines[i + 1])
                training_dict[line] = value
    for i, line in enumerate(lines):
        if line.endswith("Lv"):
            if i - 1 >= 0:
                value = re.sub(r"[^\d.]", "", lines[i - 1])
                training_dict[line] = value
                
    last_manager_index = -1
    for i, line in enumerate(lines):
        if line == "Manager":
            last_manager_index = i
    if last_manager_index != -1:
        lines = lines[:last_manager_index]
        text = "\n".join(lines)
    
    for i, line in enumerate(lines):
        if line == "Manager":
            if i + 1 < len(lines):
                value = lines[i + 1]
                training_dict[line] = value
    #print(training_dict)
    
    injury_resistance_index = -1
    for i, line in enumerate(lines):
        if line == "Injury Resistance":
            injury_resistance_index = i
    if injury_resistance_index != -1:
        lines = lines[:injury_resistance_index + 2]
        text = "\n".join(lines)
    
    attributes = ["Offensive Awareness", "Ball Control", "Dribbling", "Tight Possession", "Low Pass", 
                  "Lofted Pass", "Finishing", "Heading", "Place Kicking", "Curl", "Defensive Awareness", "Defensive Engagement", 
                  "Tackling", "Aggression", "Goalkeeping", "Gk Catching", "GK Parrying", "GK Reflexes", "GK Reach", "Speed", "Acceleration", 
                  "Kicking Power", "Jump", "Physical", "Balance", "Stamina"]
    #print(text)
    
    attributes_dict = {}
    for i, line in enumerate(lines):
        if line in attributes:
            if i + 1 < len(lines):
                value = re.sub(r"[^\d.]", "", lines[i + 1])
                # Dont overwrite key if it already exists
                if line not in attributes_dict:
                    attributes_dict[line] = value
                
    ############ BUG IN EFHUB ###################
    # Swap Defensive Engagement and Tackling values
    #mem = attributes_dict.get("Defensive Engagement")
    #attributes_dict["Defensive Engagement"] = attributes_dict.get("Tackling")
    #attributes_dict["Tackling"] = mem
    
    # Change "Physical" key for "Physical Contact"
    if "Physical" in attributes_dict:
        attributes_dict["Physical Contact"] = attributes_dict.pop("Physical")
    
    #print(attributes_dict)
    
    skills = []
    skills_start_index = -1
    skills_end_index = -1
    for i, line in enumerate(lines):
        if line == "Skills":
            skills_start_index = i
        elif line == "Additional Skills":
            skills_end_index = i
    if skills_start_index != -1 and skills_end_index != -1 and skills_end_index > skills_start_index:
        skills = lines[skills_start_index + 1:skills_end_index]
        
    # Change "Aerial Forte" for "Aerial Fort"
    skills = [skill.replace("Aerial Forte", "Aerial Fort") for skill in skills]
    #print(skills)
    
    biometrics = ["Height", "Weight","Arm Length", "Shoulder Width", "Neck Length", "Chest", "Neck Size",
                  "Shoulder Height", "Leg Length", "Thigh Size", "Waist Size", "Arm Size", "Calf Size", 
                  "Leg Coverage Radius", "Arm Coverage Radius", "Jumping Height", "Torso Collision", "Leg Length Based Height"]

    biometrics_dict = {}
    for i, line in enumerate(lines):
        if line in biometrics:
            if i + 1 < len(lines):
                value = re.sub(r"[^\d.]", "", lines[i + 1])
                biometrics_dict[line] = value
    #print(biometrics_dict)
    
    com_skills = []
    com_skills_start_index = -1
    com_skills_end_index = -1
    for i, line in enumerate(lines):
        if line == "Com Skills":
            com_skills_start_index = i
        elif line == "Other Stats":
            com_skills_end_index = i
    if com_skills_start_index != -1 and com_skills_end_index != -1 and com_skills_end_index > com_skills_start_index:
        com_skills = lines[com_skills_start_index + 1:com_skills_end_index]
    #print(com_skills)
    
    other_stats = ["Weak Foot Usage", "Weak Foot Accuracy", "Form", "Injury Resistance"]
    other_stats_dict = {}
    for i, line in enumerate(lines):
        if line in other_stats:
            if i + 1 < len(lines):
                value = lines[i + 1]
                other_stats_dict[line] = value
    # Change values to values
    for key, value in other_stats_dict.items():
        # Decode Key Weak Foot Usage
        if key == "Weak Foot Usage":
            if value == "Rarely":
                other_stats_dict[key] = 1
            elif value == "Occasionally":
                other_stats_dict[key] = 2
            elif value == "Regularly":
                other_stats_dict[key] = 3
            else:
                other_stats_dict[key] = 0
        # Decode Key Weak Foot Accuracy
        elif key == "Weak Foot Accuracy":
            if value == "Medium":
                other_stats_dict[key] = 1
            elif value == "High":
                other_stats_dict[key] = 2
            elif value == "Very High":
                other_stats_dict[key] = 3
            else:
                other_stats_dict[key] = 0
        # Decode Key Form
        elif key == "Form":
            if value == "Standard":
                other_stats_dict[key] = 1
            elif value == "Unwavering":
                other_stats_dict[key] = 2
            else:
                other_stats_dict[key] = 0
        # Decode Key Injury Resistance
        elif key == "Injury Resistance":
            if value == "High":
                other_stats_dict[key] = 2
            elif value == "Medium":
                other_stats_dict[key] = 1
            else:
                other_stats_dict[key] = 0
    #print(other_stats_dict)    
    
    output_path = os.path.join(output_folder, f"{base_name}.txt")
    with open(output_path, "w", encoding="utf-8") as f:
        f.write("Name: " + Name + "\n")
        f.write("Position: " + Position + "\n")
        f.write("Style: " + Style + "\n")
        f.write("\n")
        f.write("Training:\n")
        for key, value in training_dict.items():
            f.write(f"{key}: {value}\n")
        f.write("\n")
        f.write("Attributes:\n")
        for key, value in attributes_dict.items():
            f.write(f"{key}: {value}\n")
        f.write("\n")
        f.write("Skills:\n")
        for skill in skills:
            f.write(f"{skill}\n")
        f.write("\n")
        f.write("Biometrics:\n")
        for key, value in biometrics_dict.items():
            f.write(f"{key}: {value}\n")
        f.write("\n")
        f.write("Com Skills:\n")
        for com_skill in com_skills:
            f.write(f"{com_skill}\n")
        f.write("\n")
        f.write("Other Stats:\n")
        for key, value in other_stats_dict.items():
            f.write(f"{key}: {value}\n")
        
        print(f"\033[92mCreated file: {output_path}\033[0m")
        
        #Debug prints
        #print(f"\033[94mName: {Name}\033[0m")
        #print(f"\033[94mPosition: {Position}\033[0m")
        #print(f"\033[94mStyle: {Style}\033[0m")
        #print(f"\033[94mTraining: {training_dict}\033[0m
        #print(f"\033[94mAttributes: {attributes_dict}\033[0m")
        #print(f"\033[94mSkills: {skills}\033[0m")
        #print(f"\033[94mBiometrics: {biometrics_dict}\033[0m")
        #print(f"\033[94mCom Skills: {com_skills}\033[0m")
        #print(f"\033[94mOther Stats: {other_stats_dict}\033[0m")

def main(folder_path, prefix=""):
    output_folder = os.path.join(folder_path, "parsed_txt")
    os.makedirs(output_folder, exist_ok=True)
    for filename in os.listdir(folder_path):
        if filename.lower().endswith(".html"):
            file_path = os.path.join(folder_path, filename)
            try:
                extract_text_from_html(file_path, output_folder, prefix)
                print(f"\033[92mProcessed file: {file_path}\033[0m")
            except Exception as e:
                print(f"Error processing file {file_path}: {e}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Parse HTML files and extract data.")
    parser.add_argument("folder_path", help="Path to the folder containing HTML files")
    parser.add_argument("--prefix", default="", help="Prefix to add to the generated file names")
    args = parser.parse_args()
    main(args.folder_path, args.prefix)
